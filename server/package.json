{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "mig:gen": "pnpm build && DRIZZLE_SCHEMA=./dist/db/schema/*.js drizzle-kit generate",
    "mig:run": "drizzle-kit migrate",
    "db:reset:sql": "tsx devtools/scripts/reset-db.ts",
    "db:reset": "pnpm db:reset:sql && pnpm mig:run && pnpm seed",
    "generate:schema": "tsx devtools/scripts/generate-schema.ts",
    "seed": "tsx devtools/scripts/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.11.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/lib-storage": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@gqloom/core": "^0.16.1",
    "@gqloom/drizzle": "^0.11.0",
    "@gqloom/zod": "^0.15.2",
    "better-auth": "^1.5.4",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "4.0.1",
    "graphql": "^16.12.0",
    "lodash": "^4.17.23",
    "mercurius": "^16.7.0",
    "pg": "^8.18.0",
    "zod": "^3.25.76"
  }
}
